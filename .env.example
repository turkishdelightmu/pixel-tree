# Environment variable template — copy to .env.local and fill in real values
# .env.local is gitignored and must NEVER be committed
#
# GitHub Personal Access Token
# Required scopes: read:user
# Create at: https://github.com/settings/tokens
GH_PAT=your_github_pat_here

# Upstash Redis (rate limiting + caching)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Contribution thresholds for each tree tier (comma-separated, 6 values)
TIER_BOUNDARIES=0,50,200,500,1000,2000

# Base URL used for the embed snippet on the homepage
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
