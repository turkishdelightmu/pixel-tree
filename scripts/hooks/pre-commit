#!/usr/bin/env bash
# Pre-commit hook: block commits that contain real-looking secrets
# Checks staged files for patterns that look like real credentials
#
# Install: bash scripts/install-hooks.sh
# Or manually: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

BLOCKED=0

# Patterns to block (grep -E: extended regex, cross-platform macOS + Linux)
# GitHub PATs (classic: ghp_... and fine-grained: github_pat_...)
PAT_CLASSIC='ghp_[A-Za-z0-9]{36}'
PAT_FINE='github_pat_[A-Za-z0-9_]{82}'
# Upstash Redis REST tokens start with AeH followed by long base64
UPSTASH_TOKEN='AeH[A-Za-z0-9+/]{20,}'

check_file() {
  local file="$1"
  # Skip binary files
  if ! git diff --cached --diff-filter=d -- "$file" | grep -qI .; then
    return 0
  fi
  local content
  content=$(git diff --cached -- "$file" | grep '^+' | grep -v '^+++')

  if echo "$content" | grep -qE "$PAT_CLASSIC|$PAT_FINE"; then
    echo -e "${RED}BLOCKED:${NC} GitHub PAT detected in staged file: ${YELLOW}$file${NC}"
    BLOCKED=1
  fi

  if echo "$content" | grep -qE "$UPSTASH_TOKEN"; then
    echo -e "${RED}BLOCKED:${NC} Upstash token detected in staged file: ${YELLOW}$file${NC}"
    BLOCKED=1
  fi

  # Block real-looking assignments: KEY=<20+ char value> (covers most secret patterns)
  if echo "$content" | grep -qE '(GH_PAT|UPSTASH_REDIS_REST_TOKEN|UPSTASH_REDIS_REST_URL|API_KEY|SECRET_KEY|PRIVATE_KEY)=[A-Za-z0-9+/._-]{30,}'; then
    echo -e "${RED}BLOCKED:${NC} High-entropy secret assignment in staged file: ${YELLOW}$file${NC}"
    BLOCKED=1
  fi

  # Block .env files (except .env.example) from ever being committed
  if echo "$file" | grep -qE '^\.env' && ! echo "$file" | grep -qE '\.example$'; then
    echo -e "${RED}BLOCKED:${NC} Attempted to commit an env file: ${YELLOW}$file${NC}"
    echo -e "  Only ${YELLOW}.env.example${NC} may be committed. Real env files are gitignored."
    BLOCKED=1
  fi
}

# Iterate over all staged files
while IFS= read -r -d '' file; do
  check_file "$file"
done < <(git diff --cached --name-only --diff-filter=ACM -z)

if [[ $BLOCKED -eq 1 ]]; then
  echo ""
  echo -e "${RED}Commit rejected.${NC} Remove the secrets above before committing."
  echo "  - Real credentials belong only in .env.local (which is gitignored)"
  echo "  - Use .env.example to document required variables with placeholder values"
  exit 1
fi

exit 0
